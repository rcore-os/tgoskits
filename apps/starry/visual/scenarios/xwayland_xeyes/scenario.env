# M10 visual scenario: an X11 client (xeyes) rendering as a Wayland
# surface via Xwayland, proving native-X compatibility.
#
# The capture lands at t=30s — weston takes ~5s to start, Xwayland
# another ~6s to bind, and xeyes ~1s to paint. We wait past all of
# those plus ~10s of slack so the guest has time under TCG emulation.
CAPTURE_AFTER_SECS=50
RUN_FOR_SECS=65

# xeyes' animated pupils follow the cursor position, so a single frame
# might catch them mid-motion. Golden is captured on the fully-idle
# desktop (no cursor motion injected), so the only jitter sources are
# the panel clock and anti-alias around the eyes-circle edges.
DIFF_DELTA=16
DIFF_MAX_CHANGED_PCT=0.3

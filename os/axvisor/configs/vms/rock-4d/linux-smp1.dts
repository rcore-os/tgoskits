	rkisp-vir3-sditf {
		compatible = "rockchip,rkisp-sditf";
		status = "disabled";
		phandle = <0x1e2>;
		rockchip,isp = <0x47>;

		port {

			endpoint {
				remote-endpoint = <0x48>;
				phandle = <0x51>;
			};
		};
	};

	iommu@27920f00 {
		power-domains = <0x03 0x0d>;
		clock-names = "aclk\0iface";
		interrupts = <0x00 0x148 0x04>;
		clocks = <0x02 0x157 0x02 0x156>;
		#iommu-cells = <0x00>;
		compatible = "rockchip,iommu-v2";
		status = "disabled";
		interrupt-names = "rga2_0_mmu";
		reg = <0x00 0x27920f00 0x00 0x100>;
		phandle = <0xaf>;
	};

	dma-controller@2abd0000 {
		clock-names = "apb_pclk";
		interrupts = <0x00 0x24 0x04 0x00 0x25 0x04>;
		clocks = <0x02 0xcb>;
		arm,pl330-periph-burst;
		compatible = "arm,pl330\0arm,primecell";
		reg = <0x00 0x2abd0000 0x00 0x4000>;
		phandle = <0xd1>;
		#dma-cells = <0x01>;
	};

	i2c@2ac40000 {
		pinctrl-names = "default";
		#address-cells = <0x01>;
		pinctrl-0 = <0x139>;
		clock-names = "i2c\0pclk";
		resets = <0x02 0xcc 0x02 0xc0>;
		interrupts = <0x00 0x59 0x04>;
		clocks = <0x02 0x7a 0x02 0x6e>;
		#size-cells = <0x00>;
		compatible = "rockchip,rk3576-i2c\0rockchip,rk3399-i2c";
		status = "disabled";
		reg = <0x00 0x2ac40000 0x00 0x1000>;
		phandle = <0x277>;
		reset-names = "i2c\0apb";

		pmic@23 {
			vcc11-supply = <0x141>;
			pinctrl-names = "default\0pmic-power-off";
			vcc12-supply = <0x140>;
			vcc13-supply = <0x142>;
			vcc14-supply = <0x142>;
			pinctrl-0 = <0x13b 0x13c 0x13d 0x13e>;
			interrupts = <0x06 0x08>;
			interrupt-parent = <0x13a>;
			low_voltage_threshold = <0xbb8>;
			vcca-supply = <0x140>;
			vcc1-supply = <0x140>;
			pmic-reset-func = <0x01>;
			vcc2-supply = <0x140>;
			hotdie_temperture_threshold = <0x73>;
			compatible = "rockchip,rk806";
			vcc3-supply = <0x140>;
			pinctrl-1 = <0x13f>;
			vcc4-supply = <0x140>;
			vcc5-supply = <0x140>;
			reg = <0x23>;
			phandle = <0x278>;
			vcc6-supply = <0x140>;
			shutdown_voltage_threshold = <0xa8c>;
			vcc7-supply = <0x140>;
			vcc8-supply = <0x140>;
			shutdown_temperture_threshold = <0xa0>;
			buck5-feedback-disable;
			vcc9-supply = <0x140>;
			vcc10-supply = <0x140>;

			pinctrl_rk806 {
				gpio-controller;
				phandle = <0x279>;
				#gpio-cells = <0x02>;

				rk806_dvs2_rst {
					function = "pin_fun3";
					pins = "gpio_pwrctrl2";
					phandle = <0x27e>;
				};

				rk806_dvs3_null {
					function = "pin_fun0";
					pins = "gpio_pwrctrl3";
					phandle = <0x13e>;
				};

				rk806_dvs3_dvs {
					function = "pin_fun4";
					pins = "gpio_pwrctrl3";
					phandle = <0x284>;
				};

				rk806_dvs3_rst {
					function = "pin_fun3";
					pins = "gpio_pwrctrl3";
					phandle = <0x283>;
				};

				rk806_dvs2_null {
					function = "pin_fun0";
					pins = "gpio_pwrctrl2";
					phandle = <0x13d>;
				};

				rk806_dvs1_pwrdn {
					function = "pin_fun2";
					pins = "gpio_pwrctrl1";
					phandle = <0x13f>;
				};

				rk806_dvs1_slp {
					function = "pin_fun1";
					pins = "gpio_pwrctrl1";
					phandle = <0x27a>;
				};

				rk806_dvs1_null {
					function = "pin_fun0";
					pins = "gpio_pwrctrl2";
					phandle = <0x13c>;
				};

				rk806_dvs3_gpio {
					function = "pin_fun5";
					pins = "gpio_pwrctrl3";
					phandle = <0x285>;
				};

				rk806_dvs2_gpio {
					function = "pin_fun5";
					pins = "gpio_pwrctrl2";
					phandle = <0x280>;
				};

				rk806_dvs2_slp {
					function = "pin_fun1";
					pins = "gpio_pwrctrl2";
					phandle = <0x27c>;
				};

				rk806_dvs2_pwrdn {
					function = "pin_fun2";
					pins = "gpio_pwrctrl2";
					phandle = <0x27d>;
				};

				rk806_dvs1_rst {
					function = "pin_fun3";
					pins = "gpio_pwrctrl1";
					phandle = <0x27b>;
				};

				rk806_dvs3_slp {
					function = "pin_fun1";
					pins = "gpio_pwrctrl3";
					phandle = <0x281>;
				};

				rk806_dvs2_dvs {
					function = "pin_fun4";
					pins = "gpio_pwrctrl2";
					phandle = <0x27f>;
				};

				rk806_dvs3_pwrdn {
					function = "pin_fun2";
					pins = "gpio_pwrctrl3";
					phandle = <0x282>;
				};
			};


/dts-v1/;

/ {
    description = "StarryOS Wi-Fi for LicheeRV Nano SG2002";
    #address-cells = <1>;

    images {
        kernel {
            description = "StarryOS Wi-Fi kernel";
            data = /incbin/("${kernel_bin}");
            type = "kernel";
            arch = "riscv";
            os = "linux";
            compression = "none";
            load = <0x80200000>;
            entry = <0x80200000>;

            hash {
                algo = "sha256";
            };
        };
    };

    configurations {
        default = "config";

        config {
            description = "StarryOS SG2002 Wi-Fi";
            kernel = "kernel";
        };
    };
};

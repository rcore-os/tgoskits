  ["/chosen"],
  ["/aliases"],
  ["/pl011@9000000"],
  ["/intc@8000000"],
  ["/timer"],
  ["/psci"],
]

passthrough_addresses = []
excluded_devices = [
  ["/pcie@10000000"],
]
emu_devices = []
interrupt_mode = "passthrough"

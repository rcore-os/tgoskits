# Visual-test knobs for the "idle weston desktop" baseline.
#
# This scenario is the rendering-integrity canary: if anything
# regresses in the DRM driver, the pixman compositor, libinput probe,
# the SHM/memfd SCM_RIGHTS exchange, or any of the VNC→virtio-gpu
# capture chain, the captured frame will diverge visibly from the
# golden. We deliberately run NO animated clients — only the idle
# compositor desktop (panel + background pattern) — so the diff signal
# is deterministic and any drift is a real regression.
#
# Capture at t=25s — weston finishes initialization in ~5s; waiting
# out to 25s ensures first-commit jitter has settled and the panel
# clock has painted past its first minute boundary.
CAPTURE_AFTER_SECS=25
RUN_FOR_SECS=40

# Sole source of legitimate jitter: the panel clock rolling over one
# minute (one digit changes, ~3px * 8px = 24 pixels). Plus anti-alias
# stability around the digit glyph edges (~50 more pixels). Allow
# 0.1% to absorb both comfortably; anything beyond that is a real
# regression. delta=12 tolerates GPU quantization without masking it.
DIFF_DELTA=12
DIFF_MAX_CHANGED_PCT=0.1

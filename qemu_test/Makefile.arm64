# Minimal Makefile for AArch64 usermode test (CRC32C hardware acceleration)

TARGET ?= aarch64-unknown-linux-gnu
MODE ?= release
BIN ?= ../target/$(TARGET)/$(MODE)/rsext4

QEMU ?= qemu-aarch64
QEMU_LD ?= /usr/aarch64-linux-gnu

CARGO ?= cargo +nightly
BUILD_STD_FLAGS ?= -Zbuild-std=std,panic_abort

LINKER ?= aarch64-linux-gnu-gcc
AR ?= aarch64-linux-gnu-ar

.PHONY: build run clean

build:
	@cd ../ && \
		CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER=$(LINKER) \
		CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_AR=$(AR) \
		$(CARGO) build --$(MODE) --target $(TARGET) $(BUILD_STD_FLAGS)
	@echo "built: $(BIN)"

run: build
	@$(QEMU) -L $(QEMU_LD) $(BIN)

clean:
	@cargo clean

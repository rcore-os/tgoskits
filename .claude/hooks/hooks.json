{
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": "Edit|Write",
      "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/post-tool-use-log.py\" \"${CLAUDE_PLUGIN_ROOT}\""
    },
    {
      "event": "Stop",
      "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/stop-hook.py\""
    }
  ]
}

set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR "@CMAKE_SYSTEM_PROCESSOR@")

set(CMAKE_SYSROOT "@CMAKE_SYSROOT@")
set(CMAKE_FIND_ROOT_PATH "@CMAKE_FIND_ROOT_PATH@")

set(CMAKE_C_COMPILER "@CMAKE_C_COMPILER@")
set(CMAKE_C_COMPILER_TARGET "@CMAKE_C_COMPILER_TARGET@")
set(CMAKE_ASM_COMPILER "@CMAKE_ASM_COMPILER@")
set(CMAKE_ASM_COMPILER_TARGET "@CMAKE_ASM_COMPILER_TARGET@")

set(CMAKE_AR "@CMAKE_AR@")
set(CMAKE_RANLIB "@CMAKE_RANLIB@")
set(CMAKE_STRIP "@CMAKE_STRIP@")
set(CMAKE_LINKER "@CMAKE_LINKER@")
set(CMAKE_NM "@CMAKE_NM@")
set(CMAKE_OBJCOPY "@CMAKE_OBJCOPY@")
set(CMAKE_OBJDUMP "@CMAKE_OBJDUMP@")
set(CMAKE_READELF "@CMAKE_READELF@")
set(CMAKE_C_COMPILER_AR "@CMAKE_C_COMPILER_AR@")
set(CMAKE_C_COMPILER_RANLIB "@CMAKE_C_COMPILER_RANLIB@")

set(CMAKE_C_FLAGS_INIT "@CMAKE_C_FLAGS_INIT@")
set(CMAKE_ASM_FLAGS_INIT "@CMAKE_ASM_FLAGS_INIT@")
set(CMAKE_EXE_LINKER_FLAGS_INIT "@CMAKE_LINKER_FLAGS_INIT@")
set(CMAKE_SHARED_LINKER_FLAGS_INIT "@CMAKE_LINKER_FLAGS_INIT@")
set(CMAKE_MODULE_LINKER_FLAGS_INIT "@CMAKE_LINKER_FLAGS_INIT@")

set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
